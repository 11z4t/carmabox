#!/bin/bash
# PLAT-1212: Enforce Jira issue key prefix in commit messages.
#
# Valid formats:
#   PLAT-123: short description
#   IT-456: short description
#   PLAN-789: short description
#
# This hook is registered via: git config core.hooksPath .githooks
# Run scripts/install-hooks.sh to activate.

COMMIT_MSG_FILE="$1"
COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")

# Skip merge commits, fixup!, squash!, and revert commits
FIRST_LINE=$(head -1 "$COMMIT_MSG_FILE")
if echo "$FIRST_LINE" | grep -qE '^(Merge |Revert |fixup! |squash! )'; then
    exit 0
fi

# Check for Jira key prefix: one or more uppercase letters, dash, digits, colon+space
if ! echo "$FIRST_LINE" | grep -qE '^[A-Z][A-Z0-9]+-[0-9]+: .'; then
    echo ""
    echo "❌ commit-msg hook: commit message must start with a Jira issue key."
    echo ""
    echo "   Format: PROJ-123: short description"
    echo "   Examples:"
    echo "     PLAT-1209: Extract magic numbers to const.py"
    echo "     IT-2378: Add intelligent scheduler"
    echo ""
    echo "   Your message: $FIRST_LINE"
    echo ""
    exit 1
fi

exit 0
